<Window x:Class="FinanceTracker.WPF.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика" Width="450" Height="500">

    <StackPanel Margin="10">

        <TextBlock Text="Период с:"/>
        <DatePicker SelectedDate="{Binding FromDate}"/>

        <TextBlock Text="по:" Margin="0,5,0,0"/>
        <DatePicker SelectedDate="{Binding ToDate}"/>

        <Button Content="Обновить"
                Command="{Binding LoadStatisticsCommand}"
                Margin="0,10,0,10"/>

        <TextBlock Text="{Binding TotalIncome, StringFormat=Доходы: {0}}" />
        <TextBlock Text="{Binding TotalExpense, StringFormat=Расходы: {0}}" />
        <TextBlock Text="{Binding Balance, StringFormat=Баланс: {0}}"
                   FontWeight="Bold"
                   Margin="0,5,0,10"/>

        <TextBlock Text="Расходы по категориям" FontWeight="Bold"/>

        <ListBox ItemsSource="{Binding ExpensesByCategory}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CategoryName}" Width="200"/>
                        <TextBlock Text="{Binding TotalAmount}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Text="Доходы по категориям"
           FontWeight="Bold"
           Margin="0,10,0,5"/>

        <ListBox ItemsSource="{Binding IncomeByCategory}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CategoryName}" Width="200"/>
                        <TextBlock Text="{Binding TotalAmount}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>


    </StackPanel>
</Window>
