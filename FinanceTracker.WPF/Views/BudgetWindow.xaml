<Window x:Class="FinanceTracker.WPF.Views.BudgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Бюджеты"
        Width="900"
        Height="550">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= ЛЕВАЯ ЧАСТЬ: СПИСОК БЮДЖЕТОВ ================= -->

        <StackPanel Grid.Column="0">

            <TextBlock Text="Бюджеты"
                       FontWeight="Bold"
                       Margin="0,0,0,5"/>

            <ListBox ItemsSource="{Binding Budgets}"
                     SelectedItem="{Binding SelectedBudget}"
                     Height="250">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray"
                                BorderThickness="1"
                                Padding="5"
                                Margin="0,0,0,5">
                            <StackPanel>
                                <TextBlock Text="{Binding PeriodStart,
                                    StringFormat=Период с {0:d}}"/>
                                <TextBlock Text="{Binding PeriodEnd,
                                    StringFormat=по {0:d}}"/>
                                <TextBlock Text="{Binding TotalLimit,
                                    StringFormat=Лимит: {0}}"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Button Content="Удалить выбранный бюджет"
                    Command="{Binding DeleteBudgetCommand}"
                    Margin="0,10,0,0"/>
        </StackPanel>

        <!-- ================= ПРАВАЯ ЧАСТЬ ================= -->

        <ScrollViewer Grid.Column="1">
            <StackPanel Margin="15,0,0,0">

                <TextBlock Text="Создание / редактирование бюджета"
           FontWeight="Bold"
           Margin="0,0,0,5"/>

                <TextBlock Text="Дата начала"/>
                <DatePicker SelectedDate="{Binding EditPeriodStart}"/>

                <TextBlock Text="Дата окончания"
           Margin="0,5,0,0"/>
                <DatePicker SelectedDate="{Binding EditPeriodEnd}"/>

                <TextBlock Text="Общий лимит"
           Margin="0,5,0,0"/>
                <TextBox Text="{Binding EditTotalLimit}"
         Margin="0,0,0,5"/>

                <StackPanel Orientation="Horizontal"
            Margin="0,5,0,10">

                    <Button Content="Создать"
            Command="{Binding CreateBudgetCommand}"
            Width="120"
            Margin="0,0,5,0"/>

                    <Button Content="Сохранить изменения"
            Command="{Binding SaveBudgetCommand}"
            Width="160"/>
                </StackPanel>


                <TextBlock Text="ПРЕВЫШЕН БЮДЖЕТ"
                           Foreground="Red"
                           FontWeight="Bold"
                           Visibility="{Binding IsExceeded,
                               Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Separator Margin="0,10,0,10"/>

                <!-- ===== ЛИМИТЫ ПО КАТЕГОРИЯМ ===== -->

                <TextBlock Text="Лимиты по категориям"
                           FontWeight="Bold"
                           Margin="0,0,0,5"/>

                <DataGrid ItemsSource="{Binding CategoryLimits}"
                          SelectedItem="{Binding SelectedCategoryLimit}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          Height="250">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Категория"
                                            Binding="{Binding CategoryName}"
                                            IsReadOnly="True"/>

                        <DataGridTextColumn Header="Лимит"
                                            Binding="{Binding LimitAmount,
                                                      Mode=TwoWay,
                                                      UpdateSourceTrigger=PropertyChanged}"/>

                        <DataGridTextColumn Header="Потрачено"
                                            Binding="{Binding SpentAmount}"
                                            IsReadOnly="True"/>

                        <!-- 🔥 ИСПРАВЛЕНИЕ ОШИБКИ -->
                        <DataGridCheckBoxColumn Header="Превышен"
                                                Binding="{Binding IsExceeded,
                                                          Mode=OneWay}"
                                                IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Button Content="Сохранить лимит для выбранной категории"
                        Command="{Binding SaveCategoryLimitCommand}"
                        Margin="0,5,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
