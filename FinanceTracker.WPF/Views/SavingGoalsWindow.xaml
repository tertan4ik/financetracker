<Window x:Class="FinanceTracker.WPF.Views.SavingGoalsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Цели накопления"
        Width="600"
        Height="400">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- СПИСОК ЦЕЛЕЙ -->
        <ListBox ItemsSource="{Binding Goals}"
                 SelectedItem="{Binding SelectedGoal}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrentAmount,
                            StringFormat=Накоплено: {0}}"/>
                        <TextBlock Text="{Binding TargetAmount,
                            StringFormat=Цель: {0}}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ДЕТАЛИ -->
        <StackPanel Grid.Column="1" Margin="10,0,0,0">

            <TextBlock Text="Название"/>
            <TextBox Text="{Binding EditName}"/>

            <TextBlock Text="Целевая сумма" Margin="0,5,0,0"/>
            <TextBox Text="{Binding EditTargetAmount}"/>

            <TextBlock Text="Накоплено" Margin="0,5,0,0"/>
            <TextBox Text="{Binding EditCurrentAmount}"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Создать"
                        Command="{Binding CreateGoalCommand}"
                        Width="90"
                        Margin="0,0,5,0"/>

                <Button Content="Сохранить"
                        Command="{Binding SaveGoalCommand}"
                        Width="90"
                        Margin="0,0,5,0"/>

                <Button Content="Удалить"
                        Command="{Binding DeleteGoalCommand}"
                        Width="90"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
