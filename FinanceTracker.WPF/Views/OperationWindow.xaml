<Window x:Class="FinanceTracker.WPF.Views.OperationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Операции" Width="500" Height="600">

    <StackPanel Margin="10">

        <TextBlock Text="Сумма"/>
        <TextBox Text="{Binding Amount}" Margin="0,0,0,5"/>

        <TextBlock Text="Дата"/>
        <DatePicker SelectedDate="{Binding Date}" Margin="0,0,0,5"/>

        <TextBlock Text="Категория"/>
        <ComboBox ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory}"
                  DisplayMemberPath="Name"
                  Margin="0,0,0,5"/>

        <TextBlock Text="Комментарий"/>
        <TextBox Text="{Binding Comment}" Margin="0,0,0,10"/>

        <Button Content="Добавить операцию"
                Command="{Binding AddOperationCommand}"/>

        <Button Content="Сохранить изменения"
                Command="{Binding UpdateOperationCommand}"
                Margin="0,5,0,0"/>

        <Button Content="Удалить"
                Command="{Binding DeleteOperationCommand}"
                Margin="0,5,0,10"/>

        <ListBox ItemsSource="{Binding Operations}"
                 SelectedItem="{Binding SelectedOperation}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Date}"/>
                        <TextBlock Text="{Binding Amount}"/>
                        <TextBlock Text="{Binding Category.Name}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </StackPanel>
</Window>
