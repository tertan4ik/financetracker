<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FinanceTracker.MAUI.Views"
    x:Class="FinanceTracker.MAUI.AppShell">

    <!-- НИЖНЕЕ МЕНЮ -->
    <TabBar>

        <ShellContent
            Title="Операции"
            Icon="tab_operations.png"
            ContentTemplate="{DataTemplate views:OperationsPage}" />

        <ShellContent
            Title="Категории"
            Icon="tab_categories.png"
            ContentTemplate="{DataTemplate views:CategoriesPage}" />

        <ShellContent
            Title="Цели"
            Icon="tab_goals.png"
            ContentTemplate="{DataTemplate views:SavingGoalsPage}" />

        <ShellContent
            Title="Бюджет"
            Icon="tab_budget.png"
            ContentTemplate="{DataTemplate views:BudgetPage}" />

    </TabBar>

</Shell>
