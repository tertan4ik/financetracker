<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:FinanceTracker.MAUI.Views"
    x:Class="FinanceTracker.MAUI.AppShell">

    <!-- НИЖНЕЕ МЕНЮ -->
    <TabBar>

        <ShellContent
            Title="Операции"
   
            ContentTemplate="{DataTemplate views:OperationsPage}" />

        <ShellContent
            Title="Категории"
 
            ContentTemplate="{DataTemplate views:CategoriesPage}" />

        <ShellContent
            Title="Главная"
       
            ContentTemplate="{DataTemplate views:StatisticsPage}" />

        <ShellContent
            Title="Цели"
     
            ContentTemplate="{DataTemplate views:SavingGoalsPage}" />

        <ShellContent
            Title="Бюджет"
       
            ContentTemplate="{DataTemplate views:BudgetPage}" />



    </TabBar>

</Shell>
