<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FinanceTracker.MAUI.Views.OperationsPage"
    Title="Операции"
        xmlns:converters="clr-namespace:FinanceTracker.MAUI.Converters"
    BackgroundColor="#F2F2F2">

    <!-- ОСНОВНАЯ СЕТКА -->
    <Grid
        Padding="12"
        RowDefinitions="Auto,*,auto"
        RowSpacing="12">

        <!-- =============================== -->
        <!-- 🔘 ПЕРЕКЛЮЧАТЕЛЬ ТИПА ОПЕРАЦИЙ -->
        <!-- =============================== -->
        <Frame
    Grid.Row="0"
    Padding="4"
    CornerRadius="12"
    BackgroundColor="#EEEEEE"
    Margin="8">

            <Grid ColumnDefinitions="*,*,*">

                <!-- РАСХОДЫ -->
                <Button
            Grid.Column="0"
            Text="Расходы"
            Command="{Binding SetExpenseModeCommand}"
            BackgroundColor="{Binding CurrentMode, Converter={StaticResource ExpenseBackgroundConverter1}}"
            TextColor="{Binding CurrentMode, Converter={StaticResource ExpenseTextColorConverter1}}" />

                <!-- ДОХОДЫ -->
                <Button
            Grid.Column="1"
            Text="Доходы"
            Command="{Binding SetIncomeModeCommand}"
            BackgroundColor="{Binding CurrentMode, Converter={StaticResource IncomeBackgroundConverter1}}"
            TextColor="{Binding CurrentMode, Converter={StaticResource IncomeTextColorConverter1}}" />

                <!-- ВСЕ -->
                <Button
            Grid.Column="2"
            Text="Все"
            Command="{Binding SetAllModeCommand}"
            BackgroundColor="{Binding CurrentMode, Converter={StaticResource AllModeBackgroundConverter}}"
            TextColor="{Binding CurrentMode, Converter={StaticResource AllModeTextColorConverter}}" />

            </Grid>
        </Frame>

        <!-- =============================== -->
        <!-- 📋 СПИСОК ОПЕРАЦИЙ -->
        <!-- =============================== -->
        <Frame
            Grid.Row="1"
            Padding="0"
            CornerRadius="16"
            BackgroundColor="White">

            <CollectionView
                ItemsSource="{Binding VisibleOperations}"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <SwipeView>

                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">

                                    <SwipeItem
                                        Text="Изменить"
                                        BackgroundColor="{StaticResource EditColor}"
                                        CommandParameter="{Binding .}"
                                        Invoked="OnEditInvoked" />

                                    <SwipeItem
                                        Text="Удалить"
                                        BackgroundColor="{StaticResource DeleteColor}"
                                        CommandParameter="{Binding .}"
                                        Invoked="OnDeleteInvoked" />

                                </SwipeItems>
                            </SwipeView.RightItems>

                            <Frame
                                Padding="12"
                                Margin="6"
                                CornerRadius="12"
                                BackgroundColor="{StaticResource CardBackground}">

                                <VerticalStackLayout>

                                    <Label
                                        Text="{Binding Category.Name}"
                                        TextColor="{StaticResource PrimaryText}"
                                        FontAttributes="Bold" />
                                    <Label
                                      Text="{Binding Comment, StringFormat='{}{0:dd.MM.yyyy}'}"
                                      FontSize="12"
                                      TextColor="Gray" />

                                    <Label
                                        Text="{Binding Amount, StringFormat='{}{0:N2} ₽'}"
                                        FontAttributes="Bold">

                                        <Label.Triggers>
                                            <DataTrigger
                                                TargetType="Label"
                                                Binding="{Binding Category.Type}"
                                                Value="Доход">
                                                <Setter Property="TextColor"
                                                        Value="{StaticResource IncomeColor}" />
                                            </DataTrigger>

                                            <DataTrigger
                                                TargetType="Label"
                                                Binding="{Binding Category.Type}"
                                                Value="Расход">
                                                <Setter Property="TextColor"
                                                        Value="{StaticResource ExpenseColor}" />
                                            </DataTrigger>
                                        </Label.Triggers>

                                    </Label>

                                    <Label
                                        Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}"
                                        FontSize="12"
                                        TextColor="Gray" />

                                </VerticalStackLayout>

                            </Frame>

                        </SwipeView>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </Frame>
<Frame
    Grid.Row="2"
    Padding="14"
    CornerRadius="12"
    BackgroundColor="#2ECC71"
    HasShadow="True">

    <Frame.GestureRecognizers>
        <TapGestureRecognizer Tapped="OnAddOperationTapped"/>
    </Frame.GestureRecognizers>

    <Label
        Text="➕ Добавить операцию"
        FontSize="16"
        FontAttributes="Bold"
        TextColor="White"
        HorizontalOptions="Center"
        VerticalOptions="Center"/>
</Frame>
    </Grid>
</ContentPage>
