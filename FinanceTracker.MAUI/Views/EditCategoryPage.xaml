<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FinanceTracker.MAUI.Views.EditCategoryPage"
    Title="Редактирование категории">

    <VerticalStackLayout Padding="20" Spacing="12">
        <Label Text="Название" FontSize="14" TextColor="Gray"/>
        <Entry Text="{Binding Name}" 
               Placeholder="Введите название категории"

/>

        <Label Text="Тип операции" FontSize="14" TextColor="Gray" Margin="0,10,0,0"/>
        <Picker ItemsSource="{Binding CategoryTypes}"
                SelectedItem="{Binding SelectedCategoryType}"
   
/>

        <!-- Сообщение об ошибке -->
        <Label Text="{Binding ErrorMessage}"
               TextColor="Red"
               FontSize="12"
               IsVisible="{Binding HasErrors}"
               Margin="0,10,0,0"/>

        <Button Text="Сохранить"
                Clicked="OnSaveClicked"
                IsEnabled="{Binding IsValid}"
                BackgroundColor="#2ECC71"
                TextColor="White"
                CornerRadius="8"
                Padding="15"
                Margin="0,20,0,0"/>
    </VerticalStackLayout>
</ContentPage>