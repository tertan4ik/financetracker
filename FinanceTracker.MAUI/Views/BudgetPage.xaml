<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FinanceTracker.MAUI.Views.BudgetPage"
    Title="Бюджет"
    BackgroundColor="#F2F2F2">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="12">

            <!-- Выбор бюджета -->
            <Frame BackgroundColor="White" CornerRadius="16">
                <Picker
                    ItemsSource="{Binding Budgets}"
                    SelectedItem="{Binding SelectedBudget}"
                    ItemDisplayBinding="{Binding PeriodDisplay}" />
            </Frame>
            <Button
    Text="Удалить бюджет"
    BackgroundColor="Red"
    TextColor="White"
    Command="{Binding DeleteBudgetCommand}" />
            <!-- Общая статистика -->
            <Frame BackgroundColor="White" CornerRadius="16">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Общая статистика" FontAttributes="Bold"/>
                    <Label Text="{Binding TotalExpenses, StringFormat='Потрачено: {0:N0} ₽'}"/>
                    <Label Text="{Binding SelectedBudget.TotalLimit, StringFormat='Лимит: {0:N0} ₽'}"/>

                    <Frame
    BackgroundColor="#FDECEA"
    BorderColor="#E74C3C"
    CornerRadius="12"
    IsVisible="{Binding IsExceeded}"
    Padding="10">

                        <Label
        Text="⚠ Бюджет превышен"
        TextColor="#E74C3C"
        FontAttributes="Bold"
        HorizontalOptions="Center" />
                    </Frame>
                </VerticalStackLayout>
            </Frame>

            <!-- Редактирование бюджета -->
            <Frame BackgroundColor="White" CornerRadius="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Редактирование бюджета" FontAttributes="Bold"/>

                    <DatePicker Date="{Binding EditPeriodStart}" />
                    <DatePicker Date="{Binding EditPeriodEnd}" />

                    <Entry
                        Placeholder="Общий лимит"
                        Keyboard="Numeric"
                        Text="{Binding EditTotalLimit}" />

                    <Button
                        Text="Сохранить бюджет"
                        Command="{Binding SaveBudgetCommand}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Лимиты по категориям -->
            <Frame BackgroundColor="White" CornerRadius="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Лимиты по категориям" FontAttributes="Bold"/>

                    <CollectionView
                        ItemsSource="{Binding CategoryLimits}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedCategoryLimit}">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Padding="10" Margin="4" CornerRadius="12" BackgroundColor="#FAFAFA">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding CategoryName}" FontAttributes="Bold"/>
                                        <Label Text="{Binding SpentAmount, StringFormat='Потрачено: {0:N0} ₽'}"
                                               FontSize="12"
                                               TextColor="Gray"/>

                                        <Label
                                          Text="⚠ Лимит категории превышен"
                                          TextColor="#E74C3C"
                                          FontAttributes="Bold"
                                          FontSize="12"
                                          IsVisible="{Binding IsExceeded}" />
                                        <Entry
                                            Keyboard="Numeric"
                                            Text="{Binding LimitAmount}" />
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button
                        Text="Сохранить лимит"
                       Command="{Binding SaveCategoryLimitsCommand}"
 />
                </VerticalStackLayout>
            </Frame>

            <!-- Добавление лимита -->
            <Frame BackgroundColor="White" CornerRadius="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Добавить лимит категории" FontAttributes="Bold"/>

                    <Picker
                        Title="Категория"
                        ItemsSource="{Binding AvailableCategoriesForLimit}"
                        SelectedItem="{Binding SelectedCategoryForLimit}"
                        ItemDisplayBinding="{Binding Name}" />

                    <Entry
                        Placeholder="Лимит"
                        Keyboard="Numeric"
                        Text="{Binding NewCategoryLimitAmount}" />

                    <Button
                        Text="Добавить лимит"
                        Command="{Binding CreateCategoryLimitCommand}" />
                </VerticalStackLayout>
            </Frame>


            <Frame Padding="12" CornerRadius="12">
                <VerticalStackLayout Spacing="8">

                    <Label Text="Новый бюджет" FontAttributes="Bold" />

                    <DatePicker
            Date="{Binding PeriodStart}" />

                    <DatePicker
            Date="{Binding PeriodEnd}" />

                    <Entry
            Placeholder="Общий лимит"
            Keyboard="Numeric"
            Text="{Binding TotalLimitInput}" />
                    <Label
    Text="Заполните все обязательные поля"
    TextColor="Red"
    FontSize="12"
    IsVisible="{Binding HasErrors}" />
                    <Button
            Text="Добавить бюджет"
            Command="{Binding CreateBudgetCommand}" 
                         IsEnabled="{Binding IsValid}"
                        />

      
                          
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
