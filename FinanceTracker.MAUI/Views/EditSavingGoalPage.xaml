<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FinanceTracker.MAUI.Views.EditSavingGoalPage"
    Title="Редактирование цели">

    <VerticalStackLayout Padding="20" Spacing="12">
        <Label
            Text="Название"
            />
        <Entry
         Placeholder="Название цели"
         Text="{Binding  NewName}" />
        <Label
            Text="Целевая сумма"
            />
        <Entry
         Placeholder="Целевая сумма"
         Keyboard="Numeric"
         Text="{Binding  NewTargetAmount}" />
        <Label
            Text="Накоплено"
            />
        <Entry
         Placeholder="Накоплено"
         Keyboard="Numeric"
         Text="{Binding  NewCurrentAmount}" />
        <Label
            Text="Дедлайн"
            />
        <DatePicker
            Date="{Binding  NewDeadline}" />
        <Label
    Text="Заполните все обязательные поля"
    TextColor="Red"
    FontSize="12"
    IsVisible="{Binding HasErrors}" />
        <Button
         Text="Сохранить"
         Clicked="OnSaveClicked" 
             IsEnabled="{Binding IsValid}"
            />



    </VerticalStackLayout>
</ContentPage>
