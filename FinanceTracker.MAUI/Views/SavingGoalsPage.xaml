<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:FinanceTracker.MAUI.Converters"
    x:Class="FinanceTracker.MAUI.Views.SavingGoalsPage"
    Title="Цели"
    BackgroundColor="#F2F2F2">

    <Grid
        Padding="12"
        RowDefinitions="*,Auto"
        RowSpacing="12">

        <!-- =============================== -->
        <!-- 📋 СПИСОК ЦЕЛЕЙ -->
        <!-- =============================== -->
        <Frame
            Grid.Row="0"
            Padding="0"
            CornerRadius="16"
            BackgroundColor="White">

            <CollectionView
                ItemsSource="{Binding Goals}"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <SwipeView>

                            <!-- ===== SWIPE КНОПКИ ===== -->
                            <SwipeView.RightItems>
                                <SwipeItems Mode="Reveal">

                                    <SwipeItem
                                        Text="Изменить"
                                        BackgroundColor="Orange"
                                        CommandParameter="{Binding .}"
                                        Invoked="OnEditInvoked" />

                                    <SwipeItem
                                        Text="Удалить"
                                        BackgroundColor="Red"
                                        CommandParameter="{Binding .}"
                                        Invoked="OnDeleteInvoked" />

                                </SwipeItems>
                            </SwipeView.RightItems>

                            <!-- ===== КАРТОЧКА ЦЕЛИ ===== -->
                            <Frame
                                Margin="8"
                                Padding="12"
                                CornerRadius="12"
                                BackgroundColor="#FAFAFA">

                                <VerticalStackLayout Spacing="6">

                                    <!-- НАЗВАНИЕ -->
                                    <Label
                                        Text="{Binding Name}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        TextColor="Black" />

                                    <!-- ТЕКУЩАЯ СУММА -->
                                    <Label
                                        Text="{Binding CurrentAmount, StringFormat='Накоплено: {0:N0} ₽'}"
                                        TextColor="Black" />

                                    <!-- ЦЕЛЬ -->
                                    <Label
                                        Text="{Binding TargetAmount, StringFormat='Цель: {0:N0} ₽'}"
                                        FontSize="14"
                                        TextColor="Black" />

                                    <!-- 📊 ПРОГРЕСС -->
                                    <ProgressBar
                                        HeightRequest="6"
                                        BackgroundColor="#E0E0E0"
                                        ProgressColor="#2ECC71"
                                        Progress="{Binding ., Converter={StaticResource GoalProgressConverter}}" />

                                </VerticalStackLayout>

                            </Frame>

                        </SwipeView>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Frame>

        <!-- =============================== -->
        <!-- 🟢 КНОПКА ДОБАВЛЕНИЯ -->
        <!-- =============================== -->
        <Frame
            Grid.Row="1"
            Padding="14"
            CornerRadius="12"
            BackgroundColor="#2ECC71"
            HasShadow="True">

            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAddTapped"/>
            </Frame.GestureRecognizers>

            <Label
                Text="➕ Добавить цель"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalOptions="Center"
                VerticalOptions="Center"/>
        </Frame>

    </Grid>
</ContentPage>

