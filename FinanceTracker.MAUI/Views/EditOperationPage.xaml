<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="FinanceTracker.MAUI.Views.EditOperationPage"
    Title="Операция">

    <VerticalStackLayout Padding="12" Spacing="5">
        <Label
            Text="Тип операции"
            />
        <Picker
            Title="Тип операции"
            ItemsSource="{Binding OperationTypes}"
            SelectedItem="{Binding SelectedOperationType}" />

        <Label
            Text="Сумма"
            />
        <Entry
            Placeholder="Сумма"
            Keyboard="Numeric"
            Text="{Binding Amount}" />
        <Label
            Text="Категория"
            />
        <Picker
            Title="Категория"
            ItemsSource="{Binding FilteredCategories}"
            ItemDisplayBinding="{Binding Name}"
            SelectedItem="{Binding SelectedCategory}" />
        <Label
            Text="Дата совершения"
            />
        <DatePicker
            Date="{Binding Date}" />
        <Label
            Text="Комментарий"
            />
        <Entry
            Placeholder="Комментарий"
            Text="{Binding Comment}" />
        <Label
    Text="Заполните все обязательные поля"
    TextColor="Red"
    FontSize="12"
    IsVisible="{Binding HasErrors}" />
        <Button
            Text="Сохранить"
            Clicked="OnSaveClicked"
             IsEnabled="{Binding IsValid}"/>

    </VerticalStackLayout>
</ContentPage>
