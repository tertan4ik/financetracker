<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:FinanceTracker.Core.ViewModels;assembly=FinanceTracker.Core"
    xmlns:converters="clr-namespace:FinanceTracker.MAUI.Converters"
    x:Class="FinanceTracker.MAUI.Views.CategoriesPage"
    Title="Категории"
    BackgroundColor="#F2F2F2">

    <AbsoluteLayout>

        <!-- =============================== -->
        <!-- ⬇️ ТВОЯ СУЩЕСТВУЮЩАЯ СТРАНИЦА -->
        <!-- =============================== -->
        <Grid
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            Padding="12"
            RowDefinitions="auto,*,auto"
            RowSpacing="12">
            <!-- МЕНЮ ДОХОДЫ / РАСХОДЫ -->
            <Frame
                        Grid.Row="0"
                        Padding="4"
                        CornerRadius="12"
                        BackgroundColor="#EEEEEE"
                        Margin="8">

                <Grid ColumnDefinitions="*,*">

                    <Button
                                Grid.Column="0"
                                Text="Доходы"
                                Command="{Binding SetIncomeModeCommand}"
                                BackgroundColor="{Binding CurrentMode, Converter={StaticResource IncomeBackgroundConverter}}"
                                TextColor="{Binding CurrentMode, Converter={StaticResource IncomeTextColorConverter}}" />

                    <Button
                                Grid.Column="1"
                                Text="Расходы"
                                Command="{Binding SetExpenseModeCommand}"
                                BackgroundColor="{Binding CurrentMode, Converter={StaticResource ExpenseBackgroundConverter}}"
                                TextColor="{Binding CurrentMode, Converter={StaticResource ExpenseTextColorConverter}}" />

                </Grid>
            </Frame>
            <!-- ФРЕЙМ СПИСКА -->
            <Frame
                Grid.Row="1"
                Padding="0"
                CornerRadius="16"
                BackgroundColor="White">

                <Grid RowDefinitions="Auto">




                    <!-- СПИСОК КАТЕГОРИЙ -->
                    <CollectionView
                        Grid.Row="1"
                        ItemsSource="{Binding VisibleCategories}"
                        SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">

                                            <SwipeItem
                                                Text="Изменить"
                                                BackgroundColor="Orange"
                                                CommandParameter="{Binding .}"
                                                Invoked="OnEditInvoked" />

                                            <SwipeItem
                                                Text="Удалить"
                                                BackgroundColor="Red"
                                                CommandParameter="{Binding .}"
                                                Invoked="OnDeleteInvoked" />

                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <Frame
                                        Margin="8"
                                        Padding="12"
                                        CornerRadius="12"
                                        BackgroundColor="#FAFAFA">

                                        <Label
                                            Text="{Binding Name}"
                                            FontSize="16"
                                            FontAttributes="Bold" />

                                    </Frame>

                                </SwipeView>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </Grid>
            </Frame>
            <Frame
    Grid.Row="2"
    Padding="14"
             
    CornerRadius="12"
    BackgroundColor="#2ECC71"
    HasShadow="True">

                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAddCategoryTapped"/>
                </Frame.GestureRecognizers>

                <Label
        Text="➕ Добавить категорию"
        FontSize="16"
        FontAttributes="Bold"
        TextColor="White"
        HorizontalOptions="Center"
        VerticalOptions="Center"/>
            </Frame>
        </Grid>

        <!-- =============================== -->
        <!-- 🟢 КНОПКА ПЛЮСИКА -->
        <!-- =============================== -->


    </AbsoluteLayout>
</ContentPage>
